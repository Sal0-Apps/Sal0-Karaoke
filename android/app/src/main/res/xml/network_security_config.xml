<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- O endereço local é definido pelo usuário e normalmente usa HTTP na LAN. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
